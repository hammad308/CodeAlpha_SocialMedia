<!DOCTYPE html>
<html>

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <%- include("../partials/navbar") %>
    <div class="container mt-5">
        <h1 class="text-center mb-4">Social Feed</h1>
        <% if(posts.length>0){ %>
            <% posts.forEach(post=>{ %>
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                         <h5>
                        <%= post.user.name %>
                    </h5>
                    <samll class="text-muted">
                        <%= post.createdAt.toDateString() %>
                    </samll>
                    <hr>
                    <p>
                        <%= post.content %>
                    </p>
                    <hr>
                    <form action="/reaction/<%= post._id %>" method="post">
                        <% if(post.likesCount.includes(userId)) {%>
                        <button class="btn " type="submit">♥ <%= post.likesCount.length %> likes</button>
                        <% }else{ %>
                        <button class="btn " type="submit">♡ <%= post.likesCount.length %> likes</button>
                        <% } %>
                    </form>
                    </div>
                </div>
                <% })}else{ %>
                    <div class="btn btn-warning">There are no posts to display at this time</div>
                    <% }%>
    </div>
    </div>
</body>

</html>