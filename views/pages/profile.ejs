<!DOCTYPE html>
<html>
    <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Profile</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body>
        <%- include("../partials/navbar") %>
        <div class="container mt-5">
            
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow p-4 text-center">
                        <h2><%= user.name %></h2>
                        <p class="text-muted"><%= user.email %> </p>
                        <p>Joined: 
                            <%= user.createdAt.toDateString() %>
                        </p>
                        <form action="/create-post" method="post">
                            <textarea type="text" name="content" required rows="4" placeholder="What's on your mind?" class="mb-3 form-control"></textarea>
                            <button class="btn btn-dark w-100 mb-4">Create Post</button>
                        </form>
                        <h4 class="mt-4 mb-3">My Posts</h4>
                        <% if(posts.length>0) {%>
                        <% posts.forEach(post=>{%>
                            <div class="card shadow-sm text-start mb-3">
                                <div class="card-body">
                                    <p class="mb-2"><%= post.content %></p>
                                    <small class="text-muted">Posted on: <%= post.createdAt.toDateString() %></small>
                                </div>
                            </div>
                        <%})}else{ %>   
                            <div class="alert alert-info">
                                You haven't created any Post yet
                            </div>
                            <% }%>
                        <a href="/feed" class="btn btn-primary mb-3">Show Feed</a>
                        <hr>
                        <a href="/logout" class="btn btn-danger mb-3">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>